#!/bin/bash
set -euo pipefail

yum update -y
yum install -y docker

systemctl enable docker
systemctl start docker

mkdir -p /opt/invoice-processor

%{ if google_credentials_json != "" ~}
cat > /opt/invoice-processor/google-credentials.json <<'JSON'
${google_credentials_json}
JSON
%{ endif ~}

cat > /opt/invoice-processor/env.list <<'ENVEOF'
%{ for key, value in env_map ~}
${key}=${replace(value, "\n", "")}
%{ endfor ~}
%{ if google_credentials_json != "" ~}
GOOGLE_APPLICATION_CREDENTIALS=/opt/invoice-processor/google-credentials.json
%{ endif ~}
ENVEOF

docker pull ${app_image}
docker run --rm --env-file /opt/invoice-processor/env.list ${app_image} node dist/scripts/runWorkerOnce.js
shutdown -h now
