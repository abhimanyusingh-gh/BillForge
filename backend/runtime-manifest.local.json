{
  "defaultTenantId": "local-demo",
  "defaultWorkloadTier": "standard",
  "database": {
    "provider": "mongo",
    "uri": "mongodb://mongo:27017/invoice_processor"
  },
  "ocr": {
    "provider": "deepseek",
    "deepseek": {
      "baseUrl": "http://deepseek-ocr:8000/v1",
      "model": "deepseek-ai/DeepSeek-OCR",
      "timeoutMs": 3600000
    }
  },
  "sources": [
    {
      "type": "folder",
      "key": "local-folder",
      "tenantId": "local-demo",
      "workloadTier": "standard",
      "folderPath": "/app/sample-invoices/inbox",
      "recursive": false
    }
  ],
  "export": {
    "tallyEndpoint": "http://tally.example.local",
    "tallyCompany": "Demo Company",
    "tallyPurchaseLedger": "Purchase"
  }
}
